# RAG Guidance Pipeline — Environment Variables
# Copy this file to .env and fill in your values before running the pipeline.
# .env is git-ignored. Never commit credentials.

# ---------------------------------------------------------------------------
# GCP Core
# ---------------------------------------------------------------------------
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=global
# Location must match the DataStore region chosen during setup.
# Use "global" or "us" for Vertex AI Search.
# Use "us-central1" (or similar) if routing Gemini calls through Vertex AI.

# ---------------------------------------------------------------------------
# Google Cloud Storage
# ---------------------------------------------------------------------------
GCS_BUCKET_NAME=your-rag-corpus-bucket
# Bucket must exist in the same region as GCP_LOCATION.
# Required IAM role on this bucket: Storage Object Admin

# ---------------------------------------------------------------------------
# Vertex AI Search (Discovery Engine)
# ---------------------------------------------------------------------------
VERTEX_SEARCH_DATASTORE_ID=your-datastore-id
# The DataStore resource ID (not the full resource name).
# Created by: python scripts/setup_vertex_search.py

VERTEX_SEARCH_ENGINE_ID=your-engine-id
# The Search Engine resource ID.
# Created by: python scripts/setup_vertex_search.py

# ---------------------------------------------------------------------------
# Gemini API
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
# Leave empty to use Application Default Credentials (recommended for GCP).
# Set this when calling the Gemini API directly from a local machine.

GEMINI_MODEL_METADATA=gemini-1.5-pro
# Model for chunk metadata generation. gemini-1.5-pro recommended.
# gemini-1.5-flash is faster and cheaper but may produce lower-quality metadata.

GEMINI_MODEL_GENERATION=gemini-1.5-pro
# Model for response generation.

GEMINI_MODEL_RERANKER=gemini-1.5-flash
# Model for re-ranking retrieved results. Flash is sufficient here.

# ---------------------------------------------------------------------------
# Google Document AI (optional — OCR fallback for scanned PDFs)
# ---------------------------------------------------------------------------
USE_DOCUMENT_AI=false
# Set to "true" to always use Document AI instead of pdfplumber.
# If false, Document AI is used only as a fallback when no text layer is detected.

DOCUMENT_AI_PROCESSOR_ID=
# Full resource name, e.g.:
#   projects/123456789/locations/us/processors/abc123def456
# Leave empty to disable Document AI entirely.

# ---------------------------------------------------------------------------
# Pipeline paths
# ---------------------------------------------------------------------------
CORPUS_DIR=corpus
# Local directory to watch/scan for incoming PDFs.

MANIFEST_PATH=.ingestion_manifest.json
# JSON file tracking which PDFs have been ingested.

CHUNK_CONFIG_PATH=config/chunk_config.yaml
PROMPT_CONFIG_PATH=config/prompt_config.yaml
METADATA_SCHEMA_PATH=config/metadata_schema.json
